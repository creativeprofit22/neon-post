  "format": "square",
  "overlay": {
    "enabled": true,
    "color": "#000000",
    "opacity": 0.6
  },
  "text": {
    "position": "center",
    "fontFamily": "Anton",
    "fontSize": 72,
    "fontWeight": "400",
    "color": "#ffffff",
